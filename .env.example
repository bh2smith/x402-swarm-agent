# === Data source API keys ===
ZERION_KEY=
ALCHEMY_KEY=

# === x402 payment (Base mainnet) ===
# payTo wallet that receives USDC (falls back to a default if unset)
ADDRESS=
# Network: base (mainnet) | base-sepolia | avalanche | ...
NETWORK="base"
# Use the Coinbase CDP facilitator (required to settle on Base mainnet)
USE_CDP_FACILITATOR="true"
# Coinbase Developer Platform credentials — https://portal.cdp.coinbase.com
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# === Swarm receipts (server-side bee-js) ===
# Bee node / gateway endpoint
BEE_URL="https://api.gateway.ethswarm.org"
# Private key that owns & signs the receipts feed (hex, no 0x prefix)
BEE_FEED_PK=
# Postage batch (stamp) ID used to pay for uploads
BEE_POSTAGE_BATCH_ID=
